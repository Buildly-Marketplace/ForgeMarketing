    def _get_default_config_path(self) -> str:
        """Get default configuration file path"""
        return str(Path(__file__).parent / 'config' / 'google_ads_config.json')
    
    def _load_config(self) -> Dict[str, Any]:
        """Load Google Ads configuration"""
        try:
            if os.path.exists(self.config_file):
                with open(self.config_file, 'r') as f:
                    return json.load(f)
            else:
                # Return default configuration
                return {
                    'developer_token': os.getenv('GOOGLE_ADS_DEVELOPER_TOKEN', ''),
                    'client_id': os.getenv('GOOGLE_ADS_CLIENT_ID', ''),
                    'client_secret': os.getenv('GOOGLE_ADS_CLIENT_SECRET', ''),
                    'refresh_token': os.getenv('GOOGLE_ADS_REFRESH_TOKEN', ''),
                    'customer_ids': {
                        'foundry': os.getenv('GOOGLE_ADS_FOUNDRY_CUSTOMER_ID', ''),
                        'buildly': os.getenv('GOOGLE_ADS_BUILDLY_CUSTOMER_ID', ''),
                        'open_build': os.getenv('GOOGLE_ADS_OPENBUILD_CUSTOMER_ID', ''),
                        'radical_therapy': os.getenv('GOOGLE_ADS_RADICALTHERAPY_CUSTOMER_ID', '')
                    },
                    'api_version': 'v21',
                    'use_proto_plus': True
                }
        except Exception as e:
            self.logger.error(f"Error loading config: {e}")
            return {}
    
    def _setup_logging(self) -> logging.Logger:
        """Setup logging for Google Ads operations"""
        logger = logging.getLogger('google_ads_manager')
        logger.setLevel(logging.INFO)
        
        if not logger.handlers:
            # Create logs directory
            log_dir = Path(__file__).parent / 'logs'
            log_dir.mkdir(exist_ok=True)
            
            # File handler
            file_handler = logging.FileHandler(
                log_dir / f'google_ads_{datetime.now().strftime("%Y%m%d")}.log'
            )
            file_handler.setLevel(logging.INFO)
            
            # Console handler
            console_handler = logging.StreamHandler()
            console_handler.setLevel(logging.INFO)
            
            # Formatter
            formatter = logging.Formatter(
                '%(asctime)s - %(name)s - %(levelname)s - %(message)s'
            )
            file_handler.setFormatter(formatter)
            console_handler.setFormatter(formatter)
            
            logger.addHandler(file_handler)
            logger.addHandler(console_handler)
        
        return logger
    
    def _initialize_api_client(self):
        """Initialize Google Ads API client"""
        try:
            if self.use_mock:
                # Use mock client for development/testing
                self.logger.info("🚀 Google Ads API client initialized (Development Mode)")
                return MockGoogleAdsClient(self.config, self.logger)
            else:
                # Use real Google Ads API client
                if self.use_service_account:
                    return self._initialize_service_account_client()
                else:
                    return self._initialize_oauth_client()
                    
        except Exception as e:
            self.logger.error(f"Failed to initialize Google Ads API client: {e}")
            return None
    
    def _initialize_service_account_client(self):
        """Initialize Google Ads API client with service account authentication"""
        try:
            from google.ads.googleads.client import GoogleAdsClient
            
            # Check for required configuration
            if not self.config.get('service_account_path'):
                raise ValueError("service_account_path not configured")
            if not self.config.get('developer_token'):
                raise ValueError("developer_token not configured")
            
            # Create client configuration
            client_config = {
                'developer_token': self.config['developer_token'],
                'use_proto_plus': self.config.get('use_proto_plus', True),
                'service_account_path': self.config['service_account_path']
            }
            
            # Initialize Google Ads client
            client = GoogleAdsClient.load_from_dict(client_config)
            
            self.logger.info("🚀 Google Ads API client initialized (Service Account)")
            return RealGoogleAdsClient(client, self.config, self.logger)
            
        except ImportError:
            self.logger.error("Google Ads Python client library not installed. Run: pip install google-ads")
            raise
        except Exception as e:
            self.logger.error(f"Failed to initialize service account client: {e}")
            raise
    
    def _initialize_oauth_client(self):
        """Initialize Google Ads API client with OAuth authentication"""
        try:
            from google.ads.googleads.client import GoogleAdsClient
            
            # Check for required OAuth configuration
            required_fields = ['developer_token', 'client_id', 'client_secret', 'refresh_token']
            missing_fields = [field for field in required_fields if not self.config.get(field)]
            
            if missing_fields:
                raise ValueError(f"Missing OAuth configuration: {', '.join(missing_fields)}")
            
            # Create client configuration
            client_config = {
                'developer_token': self.config['developer_token'],
                'client_id': self.config['client_id'],
                'client_secret': self.config['client_secret'],
                'refresh_token': self.config['refresh_token'],
                'use_proto_plus': self.config.get('use_proto_plus', True)
            }
            
            # Initialize Google Ads client
            client = GoogleAdsClient.load_from_dict(client_config)
            
            self.logger.info("🚀 Google Ads API client initialized (OAuth)")
            return RealGoogleAdsClient(client, self.config, self.logger)
            
        except ImportError:
            self.logger.error("Google Ads Python client library not installed. Run: pip install google-ads")
            raise
        except Exception as e:
            self.logger.error(f"Failed to initialize OAuth client: {e}")
            raise
    
    def get_brand_campaigns(self, brand: str) -> List[Dict[str, Any]]:
        """Get all campaigns for a specific brand"""
        try:
            if brand not in self.brands:
                raise ValueError(f"Unknown brand: {brand}")
            
            campaigns = self.api_client.get_campaigns(brand) if self.api_client else []
            self.logger.info(f"Retrieved {len(campaigns)} campaigns for {brand}")
            return campaigns
        
        except Exception as e:
            self.logger.error(f"Error getting campaigns for {brand}: {e}")
            return []
    
    def create_campaign(self, brand: str, campaign_type: str, campaign_name: str, 
                       keywords: List[str] = None, budget_daily: float = None) -> Dict[str, Any]:
        """Create a new Google Ads campaign for a brand"""
        try:
            if brand not in self.brands:
                raise ValueError(f"Unknown brand: {brand}")
            
            brand_config = self.brands[brand]
            
            # Use provided keywords or default brand keywords
            campaign_keywords = keywords or brand_config['keywords']
            daily_budget = budget_daily or brand_config['budget_daily']
            
            campaign_data = {
                'name': campaign_name,
                'type': campaign_type,
                'brand': brand,
                'keywords': campaign_keywords,
                'daily_budget': daily_budget,
                'target_cpa': brand_config['target_cpa'],
                'target_audience': brand_config['target_audience'],
                'website': brand_config['website'],
                'status': 'PAUSED',  # Start paused for review
                'created_at': datetime.now().isoformat()
            }
            
            # Create campaign via API
            result = self.api_client.create_campaign(campaign_data) if self.api_client else {
                'success': True,
                'campaign_id': f"mock_campaign_{datetime.now().strftime('%Y%m%d_%H%M%S')}",
                'message': 'Campaign created successfully (Development Mode)'
            }
            
            if result.get('success'):
                self.logger.info(f"✅ Created {campaign_type} campaign '{campaign_name}' for {brand}")
                self.logger.info(f"   Campaign ID: {result.get('campaign_id')}")
                self.logger.info(f"   Daily Budget: ${daily_budget}")
                self.logger.info(f"   Keywords: {len(campaign_keywords)} keywords")
            
            return result
        
        except Exception as e:
            self.logger.error(f"Error creating campaign for {brand}: {e}")
            return {'success': False, 'error': str(e)}
    
    def get_campaign_performance(self, brand: str, days: int = 30) -> Dict[str, Any]:
        """Get campaign performance metrics for a brand"""
        try:
            if brand not in self.brands:
                raise ValueError(f"Unknown brand: {brand}")
            
            performance = self.api_client.get_performance_metrics(brand, days) if self.api_client else {}
            self.logger.info(f"Retrieved performance metrics for {brand} ({days} days)")
            return performance
        
        except Exception as e:
            self.logger.error(f"Error getting performance for {brand}: {e}")
            return {}
    
    def suggest_keywords(self, brand: str, seed_keywords: List[str] = None) -> List[Dict[str, Any]]:
        """Get keyword suggestions for a brand"""
        try:
            if brand not in self.brands:
                raise ValueError(f"Unknown brand: {brand}")
            
            brand_config = self.brands[brand]
            seeds = seed_keywords or brand_config['keywords']
            
            suggestions = self.api_client.get_keyword_suggestions(seeds, brand_config['industry']) if self.api_client else []
            self.logger.info(f"Generated {len(suggestions)} keyword suggestions for {brand}")
            return suggestions
        
        except Exception as e:
            self.logger.error(f"Error getting keyword suggestions for {brand}: {e}")
            return []
    
    def pause_campaign(self, brand: str, campaign_id: str) -> Dict[str, Any]:
        """Pause a campaign"""
        try:
            result = self.api_client.update_campaign_status(campaign_id, 'PAUSED') if self.api_client else {
                'success': True, 'message': 'Campaign paused (Development Mode)'
            }
            
            if result.get('success'):
                self.logger.info(f"⏸️  Paused campaign {campaign_id} for {brand}")
            
            return result
        
        except Exception as e:
            self.logger.error(f"Error pausing campaign {campaign_id}: {e}")
            return {'success': False, 'error': str(e)}
    
    def resume_campaign(self, brand: str, campaign_id: str) -> Dict[str, Any]:
        """Resume a campaign"""
        try:
            result = self.api_client.update_campaign_status(campaign_id, 'ENABLED') if self.api_client else {
                'success': True, 'message': 'Campaign resumed (Development Mode)'
            }
            
            if result.get('success'):
                self.logger.info(f"▶️  Resumed campaign {campaign_id} for {brand}")
            
            return result
        
        except Exception as e:
            self.logger.error(f"Error resuming campaign {campaign_id}: {e}")
            return {'success': False, 'error': str(e)}
    
    def optimize_campaigns(self, brand: str) -> Dict[str, Any]:
        """Run automated campaign optimization for a brand"""
        try:
            if brand not in self.brands:
                raise ValueError(f"Unknown brand: {brand}")
            
            self.logger.info(f"🎯 Starting campaign optimization for {brand}")
            
            # Get current campaigns
            campaigns = self.get_brand_campaigns(brand)
            optimization_results = []
            
            for campaign in campaigns:
                campaign_id = campaign.get('id')
                performance = self.get_campaign_performance(brand, days=7)  # Last 7 days
                
                # Example optimization logic
                optimizations = []
                
                # Check CTR and adjust if needed
                ctr = performance.get('ctr', 0)
                if ctr < 2.0:  # Less than 2% CTR
                    optimizations.append({
                        'type': 'keyword_refinement',
                        'action': 'Add negative keywords for low-performing terms',
                        'expected_impact': 'Improve CTR by 15-25%'
                    })
                
                # Check CPA and adjust bids
                current_cpa = performance.get('cpa', 0)
                target_cpa = self.brands[brand]['target_cpa']
                if current_cpa > target_cpa * 1.2:  # 20% over target
                    optimizations.append({
                        'type': 'bid_adjustment',
                        'action': f'Reduce bids to target CPA of ${target_cpa}',
                        'expected_impact': f'Reduce CPA by {((current_cpa - target_cpa) / current_cpa * 100):.1f}%'
                    })
                
                optimization_results.append({
                    'campaign_id': campaign_id,
                    'campaign_name': campaign.get('name'),
                    'optimizations': optimizations
                })
            
            result = {
                'brand': brand,
                'campaigns_analyzed': len(campaigns),
                'optimizations_found': sum(len(r['optimizations']) for r in optimization_results),
                'results': optimization_results,
                'timestamp': datetime.now().isoformat()
            }
            
            self.logger.info(f"✅ Optimization complete for {brand}: {result['optimizations_found']} opportunities found")
            return result
        
        except Exception as e:
            self.logger.error(f"Error optimizing campaigns for {brand}: {e}")
            return {'success': False, 'error': str(e)}
    
    def get_all_brands_summary(self) -> Dict[str, Any]:
        """Get summary of all brand campaigns"""
        summary = {
            'total_brands': len(self.brands),
            'brands': {},
            'totals': {
                'campaigns': 0,
                'daily_budget': 0,
                'clicks': 0,
                'impressions': 0,
                'conversions': 0
            },
            'last_updated': datetime.now().isoformat()
        }
        
        for brand in self.brands.keys():
            try:
                campaigns = self.get_brand_campaigns(brand)
                performance = self.get_campaign_performance(brand, days=30)
                
                brand_summary = {
                    'campaigns': len(campaigns),
                    'daily_budget': self.brands[brand]['budget_daily'],
                    'performance': performance,
                    'status': 'active' if campaigns else 'no_campaigns'
                }
                
                summary['brands'][brand] = brand_summary
                summary['totals']['campaigns'] += len(campaigns)
                summary['totals']['daily_budget'] += self.brands[brand]['budget_daily']
                summary['totals']['clicks'] += performance.get('clicks', 0)
                summary['totals']['impressions'] += performance.get('impressions', 0)
                summary['totals']['conversions'] += performance.get('conversions', 0)
                
            except Exception as e:
                self.logger.error(f"Error getting summary for {brand}: {e}")
                summary['brands'][brand] = {'error': str(e)}
        
        return summary


class MockGoogleAdsClient:
    """
    Mock Google Ads API client for development and testing
    Simulates Google Ads API responses with realistic data
    """
    
    def __init__(self, config: Dict[str, Any], logger: logging.Logger):
        self.config = config
        self.logger = logger
        self.mock_campaigns = {}
        self.mock_performance_data = {}
    
    def get_campaigns(self, brand: str) -> List[Dict[str, Any]]:
        """Mock get campaigns"""
        # Return some mock campaigns for demonstration
        mock_campaigns = [
            {
                'id': f'{brand}_search_001',
                'name': f'{brand.title()} Search Campaign',
                'type': 'SEARCH',
                'status': 'ENABLED',
                'daily_budget': 50.0,
                'created_date': '2025-10-01'
            },
            {
                'id': f'{brand}_display_001',
                'name': f'{brand.title()} Display Campaign',
                'type': 'DISPLAY',
                'status': 'PAUSED',
                'daily_budget': 30.0,
                'created_date': '2025-09-15'
            }
        ]
        
        self.logger.info(f"Mock API: Retrieved {len(mock_campaigns)} campaigns for {brand}")
        return mock_campaigns
    
    def create_campaign(self, campaign_data: Dict[str, Any]) -> Dict[str, Any]:
        """Mock create campaign"""
        campaign_id = f"mock_{campaign_data['brand']}_{datetime.now().strftime('%Y%m%d_%H%M%S')}"
        
        self.logger.info(f"Mock API: Created campaign {campaign_id}")
        return {
            'success': True,
            'campaign_id': campaign_id,
            'message': 'Campaign created successfully (Mock)'
        }
    
    def get_performance_metrics(self, brand: str, days: int) -> Dict[str, Any]:
        """Mock performance metrics"""
        import random
        
        # Generate realistic mock performance data
        base_impressions = random.randint(1000, 50000)
        base_clicks = int(base_impressions * random.uniform(0.01, 0.05))  # 1-5% CTR
        base_conversions = int(base_clicks * random.uniform(0.02, 0.10))  # 2-10% conversion rate
        
        performance = {
            'impressions': base_impressions,
            'clicks': base_clicks,
            'conversions': base_conversions,
            'ctr': round((base_clicks / base_impressions) * 100, 2),
            'conversion_rate': round((base_conversions / base_clicks) * 100, 2) if base_clicks > 0 else 0,
            'cpa': round(random.uniform(15, 50), 2),
            'cost': round(random.uniform(500, 2000), 2),
            'period_days': days
        }
        
        self.logger.info(f"Mock API: Generated performance metrics for {brand}")
        return performance
    
    def get_keyword_suggestions(self, seed_keywords: List[str], industry: str) -> List[Dict[str, Any]]:
        """Mock keyword suggestions"""
        # Generate mock keyword suggestions based on seeds
        suggestions = []
        
        for seed in seed_keywords[:3]:  # Limit to first 3 seeds
            variations = [
                f"{seed} software",
                f"{seed} platform",
                f"{seed} solution",
                f"best {seed}",
                f"{seed} tool",
                f"{seed} service"
            ]
            
            for variation in variations:
                suggestions.append({
                    'keyword': variation,
                    'search_volume': random.randint(100, 10000),
                    'competition': random.choice(['LOW', 'MEDIUM', 'HIGH']),
                    'suggested_bid': round(random.uniform(0.50, 5.00), 2),
                    'relevance_score': round(random.uniform(0.6, 1.0), 2)
                })
        
        self.logger.info(f"Mock API: Generated {len(suggestions)} keyword suggestions")
        return suggestions[:20]  # Return top 20
    
    def update_campaign_status(self, campaign_id: str, status: str) -> Dict[str, Any]:
        """Mock update campaign status"""
        self.logger.info(f"Mock API: Updated campaign {campaign_id} status to {status}")
        return {
            'success': True,
            'message': f'Campaign status updated to {status} (Mock)'
        }


def main():
    """Main function for testing Google Ads Manager"""
    print("🚀 Google Ads Manager - Development Test")
    print("=" * 50)
    
    # Initialize manager
    manager = GoogleAdsManager()
    
    # Test brand summary
    print("\n📊 All Brands Summary:")
    summary = manager.get_all_brands_summary()
    print(f"Total Brands: {summary['total_brands']}")
    print(f"Total Daily Budget: ${summary['totals']['daily_budget']}")
    
    for brand, data in summary['brands'].items():
        print(f"\n{brand.title()}:")
        print(f"  Campaigns: {data.get('campaigns', 0)}")
        print(f"  Daily Budget: ${data.get('daily_budget', 0)}")
        if 'performance' in data:
            perf = data['performance']
            print(f"  Impressions: {perf.get('impressions', 0):,}")
            print(f"  Clicks: {perf.get('clicks', 0):,}")
            print(f"  CTR: {perf.get('ctr', 0)}%")
    
    # Test campaign creation
    print(f"\n🎯 Creating test campaign for Buildly...")
    result = manager.create_campaign(
        brand='buildly',
        campaign_type='Search',
        campaign_name='Buildly Q4 2025 Search Campaign',
        keywords=['low code platform', 'rapid app development', 'business automation'],
        budget_daily=100.0
    )
    
    if result.get('success'):
        print(f"✅ Campaign created: {result.get('campaign_id')}")
    else:
        print(f"❌ Campaign creation failed: {result.get('error')}")
    
    # Test optimization
    print(f"\n🎯 Running optimization for Foundry...")
    optimization = manager.optimize_campaigns('foundry')
    
    if optimization.get('optimizations_found', 0) > 0:
        print(f"✅ Found {optimization['optimizations_found']} optimization opportunities")
        for result in optimization.get('results', []):
            print(f"  Campaign: {result['campaign_name']}")
            for opt in result['optimizations']:
                print(f"    - {opt['action']}")
    else:
        print("✅ No optimizations needed")
    
    print("\n" + "=" * 50)
    print("Google Ads Manager test completed!")


if __name__ == "__main__":
    main()