# ForgeMarketing Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to version control

# ============================================
# AI Service (Ollama)
# ============================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# ============================================
# Email / SMTP (Brevo)
# ============================================
BREVO_SMTP_USER=your-brevo-smtp-user@smtp-brevo.com
BREVO_SMTP_PASSWORD=your-brevo-smtp-password

# ============================================
# Database (optional - defaults to SQLite)
# ============================================
# DATABASE_URL=postgresql://user:password@localhost:5432/forgemarketing
# DATABASE_URL=mysql://user:password@localhost:3306/forgemarketing

# ============================================
# Twitter / X API
# ============================================
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ============================================
# LinkedIn API
# ============================================
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=

# ============================================
# Mastodon Accounts
# ============================================
MASTODON_BUILDLY_INSTANCE=https://mastodon.social
MASTODON_BUILDLY_TOKEN=
MASTODON_CLOUDNATIVE_INSTANCE=https://mastodon.social
MASTODON_CLOUDNATIVE_TOKEN=
MASTODON_OPENBUILD_INSTANCE=https://mastodon.social
MASTODON_OPENBUILD_TOKEN=

# ============================================
# Bluesky
# ============================================
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# ============================================
# YouTube API (for influencer discovery)
# ============================================
YOUTUBE_API_KEY=

# ============================================
# Google Search API (for prospect discovery)
# ============================================
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# ============================================
# SendGrid (alternative email provider)
# ============================================
SENDGRID_API_KEY=

# ============================================
# Flask App
# ============================================
FLASK_SECRET_KEY=change-this-to-a-random-string
FLASK_ENV=development
